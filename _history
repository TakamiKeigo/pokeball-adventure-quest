//www.w3.org/1999/xhtml\" _expanded=\"0\" _input_init=\"true\"></mutation><field name=\"effect\">effects.confetti</field><value name=\"win\"><shadow type=\"toggleWinLose\"><field name=\"win\">true</field></shadow></value></block></statement><next><block type=\"mapplaceonrandomtile\"><comment pinned=\"false\" h=\"80\" w=\"160\">Replacer le joueur</comment><value name=\"sprite\"><block type=\"variables_get\"><field name=\"VAR\" id=\"!)rqw[TzFJyhiO233a93\">mySprite</field></block></value><value name=\"tile\"><shadow type=\"tileset_tile_picker\"><field name=\"tile\">assets.tile`myTile1`</field></shadow></value><next><block type=\"function_call\"><mutation name=\"apparaitrePokemonAleatoire\" functionid=\"`fvS;Wr=aqT:P;HR/6;t\"></mutation><comment pinned=\"false\" h=\"80\" w=\"160\">Créer le premier Pokémon (aléatoire) du nouveau niveau</comment></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"// --- Fonction pour changer de monde ---\nfunction passerAuNiveauSuivant () {\n    niveauActuel += 1\n    info.setScore(0)\n    // On nettoie les Pokémon qui resteraient du niveau précédent\n    sprites.destroyAllSpritesOfKind(SpriteKind.Food)\n    if (niveauActuel >= 2) {\n        tiles.setCurrentTilemap(tilemap`level 2`)\n        game.splash(\"Bienvenue au Niveau 2 !\")\n    } else if (niveauActuel >= 3) {\n        tiles.setCurrentTilemap(tilemap`niveau2`)\n        game.splash(\"Bienvenue au Niveau 3 !\")\n    } else if (niveauActuel == 4) {\n        tiles.setCurrentTilemap(tilemap`niveau3`)\n        game.splash(\"Dernier Niveau !\")\n    } else {\n        game.over(true)\n    }\n    // Replacer le joueur\n    tiles.placeOnRandomTile(mySprite, assets.tile`myTile1`)\n    // Créer le premier Pokémon (aléatoire) du nouveau niveau\n    apparaitrePokemonAleatoire()\n}\n// --- Fonction pour créer un Pokémon au hasard ---\n// Cette fonction choisit une image au hasard parmi tes Pokémon\nfunction apparaitrePokemonAleatoire () {\n    // Change 3 par le nombre de Pokémon que tu as\n    de = Math.randomRange(1, 5)\n    if (de == 1) {\n        nouveauPokemon = sprites.create(assets.image`Pikachu`, SpriteKind.Food)\n    } else if (de == 2) {\n        nouveauPokemon = sprites.create(assets.tile`myTile3`, SpriteKind.Food)\n    } else {\n        nouveauPokemon = sprites.create(assets.tile`myTile5`, SpriteKind.Food)\n    }\n    // On le place sur une case sol (vérifie si c'est myTile1 ou myTile8)\n    tiles.placeOnRandomTile(nouveauPokemon, sprites.castle.tilePath5)\n    // On le place sur une case sol (vérifie si c'est myTile1 ou myTile8)\n    tiles.placeOnRandomTile(nouveauPokemon, assets.tile`myTile1`)\n}\n// --- Gestion des collisions ---\nsprites.onOverlap(SpriteKind.Player, SpriteKind.Food, function (sprite, otherSprite) {\n    otherSprite.destroy(effects.disintegrate, 200)\n    music.baDing.play()\n    info.changeScoreBy(1)\n    if (info.score() >= 5) {\n        passerAuNiveauSuivant()\n    } else {\n        // Au lieu de créer toujours un Pikachu, on appelle notre fonction aléatoire\n        apparaitrePokemonAleatoire()\n    }\n})\nlet nouveauPokemon: Sprite = null\nlet de = 0\nlet mySprite: Sprite = null\nlet niveauActuel = 0\n// --- Initialisation des variables ---\nlet pokemon = null\nniveauActuel = 1\n// --- CONFIGURATION INITIALE ---\n// Musique (en arrière-plan)\nmusic.play(music.createSong(hex`0078000408020100001c00010a006400f4016400000400000000000000000000000000050000045e000000040002242908000c000222270c001000012a100014000324272a18001c00031d20251c00200002252920002400011e24002800012428002c0001252c0030000224273000340001253400380002242738003c00012c3c00400002272a`), music.PlaybackMode.LoopingInBackground)\nscene.setBackgroundColor(13)\ntiles.setCurrentTilemap(tilemap`level1`)\n// Création de la Pokéball\nmySprite = sprites.create(assets.image`Pokeball`, SpriteKind.Player)\ncontroller.moveSprite(mySprite)\nscene.cameraFollowSprite(mySprite)\neffects.blizzard.startScreenEffect()\n// Lancement du tout premier Pokémon\napparaitrePokemonAleatoire()\nmySprite.setStayInScreen(true) // Empêche juste de sortir de l'écran\nfunction apparaitrePokemonAleatoire() {\n    de = Math.randomRange(1, 4) // 1 à 3 = Gentils, 4 = Danger !\n\n    if (de == 1) {\n        nouveauPokemon = sprites.create(assets.image`Pikachu`, SpriteKind.Food)\n    } else if (de == 2) {\n        nouveauPokemon = sprites.create(assets.image`Carapuce`, SpriteKind.Food)\n    } else if (de == 3) {\n        nouveauPokemon = sprites.create(assets.image`Bulbizarre`, SpriteKind.Food)\n    } else {\n        // --- LE POKÉMON DE FEU (DANGER) ---\n        nouveauPokemon = sprites.create(assets.image`Salameche`, SpriteKind.Enemy)\n\n        // 1. Il poursuit le joueur (vitesse 60, un peu moins vite que toi)\n        nouveauPokemon.follow(mySprite, 60)\n\n        // 2. Il a une durée de vie de 5 secondes (5000 millisecondes)\n        nouveauPokemon.setLifespan(5000)\n\n        // 3. Petit effet visuel pour montrer qu'il est dangereux\n        nouveauPokemon.startEffect(effects.fire, 5000)\n    }\n\n    tiles.placeOnRandomTile(nouveauPokemon, assets.tile`myTile1`)\n}\n\n// --- N'oublie pas le bloc de défaite si tu ne l'as pas encore mis ---\nsprites.onOverlap(SpriteKind.Player, SpriteKind.Enemy, function (sprite, otherSprite) {\n    game.over(false, effects.melt) // Perdu si on touche le feu !\n})","README.md":" ","assets.json":"","tilemap.g.jres":"{\n    \"transparency16\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"tilemapTile\": true\n    },\n    \"tile1\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==\",\n    